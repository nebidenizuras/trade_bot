//@version=5
indicator("NDU Signal Scanner", overlay=true, max_labels_count=500)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
volumeRatio     = input.float(1.1,    "Hacim Artış Oranı",      step=0.05)
minBodyPct      = input.float(0.75,   "Min Mum Gövdesi (%)",    step=0.05)
bigBodyPct      = input.float(3.0,    "Büyük Gövde Eşiği (%)",  step=0.1)
useVolFilter    = input.bool(true,    "Hacim Filtresi Uygula")
minVol15m       = input.float(2500000,"Min Hacim - 15m ($)",    step=100000)
minVol1h        = input.float(9000000,"Min Hacim - 1h ($)",     step=100000)
showEma         = input.bool(true,    "EMA8 Göster")
minScore        = input.int(2,        "Min Sinyal Skoru",        minval=1, maxval=9)

// ─── EMA8 ─────────────────────────────────────────────────────────────────────
ema8 = ta.ema(close, 8)

// ─── HACIM FİLTRESİ ───────────────────────────────────────────────────────────
dollarVolume = close * volume

volumeFilterPassed =
  if not useVolFilter
      true
  else if timeframe.period == "15"
      dollarVolume >= minVol15m
  else if timeframe.period == "60"
      dollarVolume >= minVol1h
  else
      true

// ─── LONG SKORU ───────────────────────────────────────────────────────────────
bodyPctLong = (close - open) / open * 100

longValid =
  close  > ema8      and
  close  > open      and
  bodyPctLong >= minBodyPct and
  volumeFilterPassed

longScore = 0
if longValid
  longScore := 0
  longScore += 1                                    // close > ema8
  longScore += 1                                    // close > open (bullish candle)
  if volume > volume[1] * volumeRatio
      longScore += 1                                // hacim artışı (son mum)
  if volume[1] > volume[2] * volumeRatio
      longScore += 1                                // hacim artışı (önceki mum)
  if close[1] < ema8[1]
      longScore += 1                                // önceki mum EMA altındaydı
  if close[2] < ema8[2]
      longScore += 1                                // 2 mum önce EMA altındaydı
  if bodyPctLong > bigBodyPct
      longScore += 3                                // güçlü mum gövdesi bonus

// ─── SHORT SKORU ──────────────────────────────────────────────────────────────
bodyPctShort = (open - close) / open * 100

shortValid =
  close  < ema8      and
  close  < open      and
  bodyPctShort >= minBodyPct and
  volumeFilterPassed

shortScore = 0
if shortValid
  shortScore := 0
  shortScore += 1                                   // close < ema8
  shortScore += 1                                   // close < open (bearish candle)
  if volume > volume[1] * volumeRatio
      shortScore += 1
  if volume[1] > volume[2] * volumeRatio
      shortScore += 1
  if close[1] > ema8[1]
      shortScore += 1
  if close[2] > ema8[2]
      shortScore += 1
  if bodyPctShort > bigBodyPct
      shortScore += 3

// ─── SİNYAL KOŞULLARI ─────────────────────────────────────────────────────────
longSignal  = longValid  and longScore  >= minScore
shortSignal = shortValid and shortScore >= minScore

// ─── EMA ÇİZGİSİ ──────────────────────────────────────────────────────────────
plot(showEma ? ema8 : na, "EMA 8", color=color.new(color.orange, 0), linewidth=2)

// ─── OKLAR ────────────────────────────────────────────────────────────────────
plotshape(
  longSignal,
  title     = "Long Sinyal",
  style     = shape.triangleup,
  location  = location.belowbar,
  color     = color.new(color.lime, 0),
  size      = size.normal
)

plotshape(
  shortSignal,
  title     = "Short Sinyal",
  style     = shape.triangledown,
  location  = location.abovebar,
  color     = color.new(color.red, 0),
  size      = size.normal
)

// ─── SKOR ETİKETLERİ ──────────────────────────────────────────────────────────
if longSignal
  label.new(
      x       = bar_index,
      y       = low  * 0.998,
      text    = "▲ " + str.tostring(longScore),
      style   = label.style_label_up,
      color   = color.new(color.lime, 10),
      textcolor = color.black,
      size    = size.small
  )

if shortSignal
  label.new(
      x       = bar_index,
      y       = high * 1.002,
      text    = "▼ " + str.tostring(shortScore),
      style   = label.style_label_down,
      color   = color.new(color.red, 10),
      textcolor = color.white,
      size    = size.small
  )

// ─── ALERT KOŞULLARI ──────────────────────────────────────────────────────────
alertcondition(longSignal,  "Long Sinyal",  "🟢 LONG | Skor: " + str.tostring(longScore))
alertcondition(shortSignal, "Short Sinyal", "🔴 SHORT | Skor: " + str.tostring(shortScore))
